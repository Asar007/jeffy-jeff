{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "redirects": [
    {
      "source": "/",
      "has": [{ "type": "query", "key": "token_hash" }],
      "destination": "/auth-callback.html"
    },
    {
      "source": "/",
      "has": [{ "type": "query", "key": "access_token" }],
      "destination": "/auth-callback.html"
    },
    { "source": "/index.html", "destination": "/", "permanent": true }
  ],
  "rewrites": [
    { "source": "/", "destination": "/propnri-saas-site.html" }
  ]
}
